  force,\n100\t\t\t\t\tReview:               reviewFlag,\n101\t\t\t\t\tReviewSkillsOverride: skillsFlag,\n102\t\t\t\t}\n103\t\t\t\treturn runAttachSurfaceReviewErrors(cmd, args[0], agentName, opts)\n104\t\t\t},\n105\t\t}\n106\t\tcmd.Flags().BoolVarP(&force, \"force\", \"f\", false, \"Skip confirmation and amend the last commit with the checkpoint trailer\")\n107\t\tcmd.Flags().StringVarP(&agentFlag, \"agent\", \"a\", string(agent.DefaultAgentName), \"Agent that created the session (see 'entire agent list' for registered agents, including external)\")\n108\t\tcmd.Flags().BoolVar(&reviewFlag, \"review\", false, \"Tag the attached session as an agent review\")\n109\t\tcmd.Flags().StringSliceVar(&skillsFlag, \"skills\", nil, \"Optional: declare which review skills were run in this session. Only used with --review\")\n110\t\treturn cmd\n111\t}\n112\t\n113\t// resolveReviewSkills returns the skills list to record on an\n114\t// attach-as-review. Only the user's --skills flag counts: configured\n115\t// settings.Review[agent] is the spawn-path default (\"what I'd run if I\n116\t// used 'entire review'\"), not a claim about what actually happened in a\n117\t// given manual session. Silently attaching configured skills would\n118\t// misrepresent the session as having run skills it may not have.\n119\t//\n120\t// Empty is a valid result — the attach still tags the session as a\n121\t// review via Kind + ReviewPrompt (the session's first user prompt). The\n122\t// skills list is a queryable convenience, not the source of truth.\n123\tfunc resolveReviewSkills(flagSkills []string) []string {\n124\t\tif len(flagSkills) == 0 {\n125\t\t\treturn nil\n126\t\t}\n127\t\treturn flagSkills\n128\t}\n129\t\n130\t// runAttachSurfaceReviewErrors wraps runAttach so review-mode errors reach\n131\t// the user as clear stderr messages rather than generic cobra error output.\n132\t// The non-review path preserves the existing runAttach return-err behavior.\n133\tfunc runAttachSurfaceReviewErrors