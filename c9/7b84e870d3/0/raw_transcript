n true, tags the attached session as a review. Skills are\n46\t\t// resolved inside runAttach after the real agent is known (via session\n47\t\t// state or transcript auto-detection), not at the cobra layer — the\n48\t\t// --agent flag's default points at claude-code, which would otherwise\n49\t\t// make a Gemini session incorrectly look up review.claude-code config.\n50\t\tReview bool\n51\t\t// ReviewSkillsOverride, when non-empty, declares which review skills were\n52\t\t// run. Empty is valid: the session is still tagged as a review, with no\n53\t\t// structured skills list. Ignored when Review=false.\n54\t\tReviewSkillsOverride []string\n55\t\t// ReviewPromptOverride, when non-empty, is recorded instead of the\n56\t\t// transcript's first user prompt. Used by `entire review attach` when a\n57\t\t// pending-review marker has the exact prompt the user was asked to run.\n58\t\tReviewPromptOverride string\n59\t}\n60\t\n61\tfunc newAttachCmd() *cobra.Command {\n62\t\tvar (\n63\t\t\tforce      bool\n64\t\t\tagentFlag  string\n65\t\t\treviewFlag bool\n66\t\t\tskillsFlag []string\n67\t\t)\n68\t\tcmd := &cobra.Command{\n69\t\t\tUse:   \"attach <session-id>\",\n70\t\t\tShort: \"Attach an existing agent session\",\n71\t\t\tLong: `Attach an existing agent session that wasn't captured by hooks.\n72\t\n73\tThis creates a checkpoint from the session's transcript and links it to the\n74\tlast commit. Use this when hooks failed to fire or weren't installed when\n75\tthe session started, or to attach a research session.\n76\t\n77\tIf the last commit already has a checkpoint, the session is added to it.\n78\tOtherwise a new checkpoint is created.\n79\t\n80\tUse --review to tag the attached session as an agent review. The\n81\tfirst user prompt in the transcript is recorded as the review prompt.\n82\tPass --skills to declare which skills were actually run; omit to\n83\tattach a review without a declared skills list.\n84\t\n85\tWorks with any registered agent, including external agents enabled via\n86\texternal_agents in settings. Run 'entire agent list' to see the full list.`,\n87\t\t\tRunE: func(cmd *cobra.Command, args []string) error {\n88\t\t\t\tif len(args) != 1 {\n89\t\t\t\t\treturn cmd.Help()\n90\t\t\t\t}\n91\t\t\t\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\n92\t\t\t\t\treturn nil\n93\t\t\t\t}\n94\t\t\t\t// Discover external agents so --agent <external-name> is recognized\n95\t\t\t\t// and so auto-detection can find transcripts from external agents.\n96\t\t\t\texternal.DiscoverAndRegister(cmd.Context())\n97\t\t\t\tagentName := types.AgentName(agentFlag)\n98\t\t\t\topts := attachOptions{\n99\t\t\t\t\tForce:                force,\n100\t\t\t\t\tReview:               reviewFlag,\n101\t\t\t\t\tReviewSkillsOverride: skillsFlag,\n102\t\t\t\t}\n103\t\t\t\treturn runAttachSurfaceReviewErrors(cmd, args[0], agentName, opts)\n104\t\t\t},\n105\t\t}\n106\t\tcmd.Flags().BoolVarP(&force, \"force\", \"f\", false, \"Skip confirmation and amend the last commit with the checkpoint trailer\")\n107\t\tcmd.Flags().StringVarP(&agentFlag, \"agent\", \"a\", string(agent.DefaultAgentName), \"Agent that created the session (see 'entire agent list' for registered agents, including external)\")\n108\t\tcmd.Flags().BoolVar(&reviewFlag, \"review\", false, \"Tag the attached session as an agent review\")\n109\t\tcmd.Flags().StringSliceVar(&skillsFlag, \"skills\", nil, \"Optional: declare which review skills were run in this session. Only used with --review\")\n110\t\treturn cmd\n111\t}\n112\t\n113\t// resolveReviewSkills returns the skills list to record on an\n114\t// attach-as-review. Only the user's --skills flag counts: configured\n115\t// settings.Review[agent] is the spawn-path default (\"what I'd run if I\n116\t// used 'entire review'\"), not a claim about what actually happened in a\n117\t// given manual session. Silently attaching configured skills would\n118\t// misrepresent the session as having run skills it may not have.\n119\t//\n120\t// Empty is a valid result — the attach still tags the session as a\n121\t// review via Kind + ReviewPrompt (the session's first user prompt). The\n122\t// skills list is a queryable convenience, not the source of truth.\n123\tfunc resolveReviewSkills(flagSkills []string) []string {\n124\t\tif len(flagSkills) == 0 {\n125\t\t\treturn nil\n126\t\t}\n127\t\treturn flagSkills\n128\t}\n129\t\n130\t// runAttachSurfaceReviewErrors wraps runAttach so review-mode errors reach\n131\t// the user as clear stderr messages rather than generic cobra error output.\n132\t// The non-review path preserves the existing runAttach return-err behavior.\n133\tfunc runAttachSurfaceReviewErrors(cmd *cobra.Command, sessionID string, agentName types.AgentName, opts attachOptions) error {\n134\t\terr := runAttach(cmd.Context(), cmd.OutOrStdout(), sessionID, agentName, opts)\n135\t\tif err != nil && opts.Review {\n136\t\t\tcmd.SilenceUsage = true\n137\t\t\tfmt.Fprintln(cmd.ErrOrStderr(), err.Error())\n138\t\t\treturn NewSilentError(err)\n139\t\t}\n140\t\treturn err\n141\t}\n142\t\n143\tfunc runAttach(ctx context.Context, w io.Writer, sessionID string, agentName types.AgentName, opts attachOptions) error {\n144\t\t// Initialize structured logger so logging.Warn/Info write to .entire/logs/ not stderr.\n145\t\tif err := logging.Init(ctx, sessionID); err != nil {\n146\t\t\t// Init failed — logging will use stderr fallback, non-fatal.\n147\t\t\t_ = err\n148\t\t}\n149\t\t// Flush the 8KB buffered log writer on exit. Without this, any\n150\t\t// Warn/Info calls during attach (including the overwrite tripwire)\n151\t\t// get silently dropped when the process exits, matching the pattern\n152\t\t// already used by resume/clean/reset/rewind/migrate/explain.\n153\t\tdefer logging.Close()\n154\t\n155\t\tlogCtx := logging.WithComponent(ctx, \"attach\")\n156\t\n157\t\t// Open repository once — shared across all operations.\n158\t\trepo, err := openRepository(ctx)\n159\t\tif err != nil {\n160\t\t\treturn err\n161\