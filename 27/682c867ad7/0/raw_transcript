iginal session intent\n- falls back to a single `entire dispatch --local --since <window>` for branches with more than 10 commits\n- if no commit in the push range has Entire context, silently falls back to a git-only PR equivalent to upstream `commit-commands:commit-push-pr`\n- always opens the PR as `--draft`; updates an existing open PR via `gh pr edit` instead of creating a duplicate\n- never uses `entire search` (server-indexed, missing local checkpoints) or `git add -A`/`git add .`\n\nPick this over `commit-commands:commit-push-pr` when the branch was driven by Entire-tracked agent work; pick the upstream one when there is no Entire history to draw on.\n\n## Installation"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":407,"cache_read_input_tokens":88824,"output_tokens":908,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":407,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[{"input_tokens":1,"output_tokens":908,"cache_read_input_tokens":88824,"cache_creation_input_tokens":407,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":407},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CaacFdLQDPMn8Nqyrbfpu","type":"assistant","uuid":"4fffd65c-4576-4d72-ad0e-d28bb803429a","timestamp":"2026-04-30T20:45:15.238Z","userType":"external","entrypoint":"cli","cwd":"/Users/alisha/Projects/skills","sessionId":"a88641f6-df38-4dda-89ef-d14176b173e6","version":"2.1.123","gitBranch":"alisha/commit"}
